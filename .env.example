# ============================================
# Environment Configuration for Microservices
# ============================================
# Copy this file to .env and modify values as needed

# ============================================
# SERVICE PORTS
# ============================================
API_GATEWAY_PORT=9000
PRODUCT_SERVICE_PORT=8080
ORDER_SERVICE_PORT=8081
INVENTORY_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083

# ============================================
# KEYCLOAK CONFIGURATION
# ============================================
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_PORT=8086
KC_DB_VENDOR=mysql
KC_DB_DATABASE=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=password

# ============================================
# MYSQL CONFIGURATION
# ============================================
# Order Service Database
MYSQL_ORDER_DATABASE=manu-orderdb-ms
MYSQL_ORDER_USER=manu
MYSQL_ORDER_PASSWORD=1234
MYSQL_ORDER_PORT=3307

# Inventory Service Database
MYSQL_INVENTORY_DATABASE=manu-inventoryrdb-ms
MYSQL_INVENTORY_ROOT_PASSWORD=1234
MYSQL_INVENTORY_PORT=3308

# Keycloak Database
KEYCLOAK_MYSQL_ROOT_PASSWORD=root
KEYCLOAK_MYSQL_DATABASE=keycloak
KEYCLOAK_MYSQL_USER=keycloak
KEYCLOAK_MYSQL_PASSWORD=password

# ============================================
# MONGODB CONFIGURATION
# ============================================
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=1234
MONGO_DATABASE=product-service
MONGO_PORT=27017

# ============================================
# KAFKA CONFIGURATION
# ============================================
KAFKA_BROKER_PORT=9092
KAFKA_INTERNAL_PORT=29092
ZOOKEEPER_PORT=2181
SCHEMA_REGISTRY_PORT=8085

# ============================================
# OBSERVABILITY CONFIGURATION
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100
TEMPO_PORT=3200

# ============================================
# BUILDPACKS CONFIGURATION
# ============================================
# Pack CLI configuration for building images
BUILDPACK_BUILDER=paketobuildpacks/builder-jammy-full:latest
JAVA_VERSION=21
BP_JVM_VERSION=21.0.0

# ============================================
# APPLICATION CONFIGURATION
# ============================================
SPRING_PROFILES_ACTIVE=docker
SPRING_APPLICATION_NAME=microservice-project
LOG_LEVEL=INFO

# ============================================
# DOCKER COMPOSE
# ============================================
COMPOSE_PROJECT_NAME=ms-project
COMPOSE_FILE=docker-compose.yml
